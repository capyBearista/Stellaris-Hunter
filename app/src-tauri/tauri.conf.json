{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stellaris Hunter",
  "version": "0.1.0",
  "identifier": "com.stellaris-hunter.scan",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Stellaris Hunter",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  }
}
